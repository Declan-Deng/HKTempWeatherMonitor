    {
        "id": "fn.rt.to.charts",
        "type": "function",
        "z": "9f6b2c4a.d1e3f8",
        "name": "Format Realtime Charts",
        "func": "const src = msg.payload || [];\nconst rows = Array.isArray(src) ? src.slice() : Object.values(src);\n\nfunction toNumber(v) {\n    const n = Number(v);\n    return Number.isFinite(n) ? n : null;\n}\n\nfunction pearson(data, keyX, keyY) {\n    const pairs = data\n        .map((row) => [toNumber(row[keyX]), toNumber(row[keyY])])\n        .filter((pair) => pair[0] !== null && pair[1] !== null);\n\n    if (pairs.length < 2) {\n        return null;\n    }\n\n    const n = pairs.length;\n    const sumX = pairs.reduce((s, p) => s + p[0], 0);\n    const sumY = pairs.reduce((s, p) => s + p[1], 0);\n    const sumXY = pairs.reduce((s, p) => s + p[0] * p[1], 0);\n    const sumX2 = pairs.reduce((s, p) => s + p[0] * p[0], 0);\n    const sumY2 = pairs.reduce((s, p) => s + p[1] * p[1], 0);\n\n    const numerator = (n * sumXY) - (sumX * sumY);\n    const denomX = (n * sumX2) - (sumX * sumX);\n    const denomY = (n * sumY2) - (sumY * sumY);\n    const denominator = Math.sqrt(denomX * denomY);\n\n    if (!Number.isFinite(denominator) || denominator === 0) {\n        return null;\n    }\n\n    return Number((numerator / denominator).toFixed(4));\n}\n\nfunction displayCorrelation(value) {\n    return value === null ? \"N/A\" : value;\n}\n\nrows.sort((a, b) => new Date(a.collectedAt || a.updateTime).getTime() - new Date(b.collectedAt || b.updateTime).getTime());\n\nconst tempSeries = [];\nconst stressSeries = [];\nconst rainSeries = [];\n\nfor (const row of rows) {\n    const x = new Date(row.collectedAt || row.updateTime || Date.now());\n    const avgTemp = toNumber(row.avgTemp);\n    const heatStress = toNumber(row.heatStress);\n    const maxRain = toNumber(row.maxRainfall);\n\n    if (avgTemp !== null) {\n        tempSeries.push({ x: x, y: avgTemp });\n    }\n    if (heatStress !== null) {\n        stressSeries.push({ x: x, y: heatStress });\n    }\n    if (maxRain !== null) {\n        rainSeries.push({ x: x, y: maxRain });\n    }\n}\n\nconst latest = rows.length ? rows[rows.length - 1] : null;\nconst corrTempStress = pearson(rows, 'avgTemp', 'heatStress');\nconst corrRainStress = pearson(rows, 'maxRainfall', 'heatStress');\nconst rainAxisMax = rainSeries.length ? Math.max.apply(null, rainSeries.map((point) => point.y)) : 0;\nconst rainDisplayMax = rainAxisMax <= 0 ? 1 : Math.max(1, Math.ceil(rainAxisMax * 1.2));\nconst anchorTime = latest ? new Date(latest.collectedAt || latest.updateTime || Date.now()) : new Date();\nconst rainAxisAnchor = [{ x: anchorTime, y: rainDisplayMax }];\n\nconst msgTempStress = {\n    payload: [{\n        series: [\"Avg Temp (C)\", \"Heat Stress\"],\n        data: [tempSeries, stressSeries],\n        labels: [\"\"]\n    }]\n};\n\nconst msgRain = {\n    payload: [{\n        series: [\"Max Rainfall (mm)\", \"Axis Anchor\"],\n        data: [rainSeries, rainAxisAnchor],\n        labels: [\"\"]\n    }]\n};\n\nconst msgSummary = {\n    payload: {\n        points: rows.length,\n        latest: latest,\n        corrTempHeatStress: displayCorrelation(corrTempStress),\n        corrRainHeatStress: displayCorrelation(corrRainStress)\n    }\n};\n\nreturn [msgTempStress, msgRain, msgSummary];",
        "outputs": 3,
        "noerr": 0,
        "x": 940,
        "y": 490,
        "wires": [
            [
                "chart.heat"
            ],
            [
                "chart.rain"
            ],
            [
                "dbg.rt.summary",
                "ui.text.latest",
                "ui.text.risk",
                "ui.text.rain",
                "ui.text.corr.temp",
                "ui.text.corr.rain"
            ]
        ]
    },
