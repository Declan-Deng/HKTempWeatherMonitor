    {
        "id": "fn.rt.normalize",
        "type": "function",
        "z": "9f6b2c4a.d1e3f8",
        "name": "Normalize Realtime Snapshot",
        "func": "const raw = msg.payload || {};\nconst last = flow.get('lastRealtimeUpdateTime') || \"\";\nconst updateISO = raw.updateTime ? new Date(raw.updateTime).toISOString() : \"\";\nconst sourceUpdated = !!updateISO && updateISO > last;\n\n// Incremental mode: only insert when source updateTime changes.\nif (!sourceUpdated) {\n    return null;\n}\nflow.set('lastRealtimeUpdateTime', updateISO);\n\nfunction toNumber(v) {\n    const n = Number(v);\n    return Number.isFinite(n) ? n : null;\n}\n\nfunction avg(nums) {\n    if (!nums.length) return null;\n    return nums.reduce((s, v) => s + v, 0) / nums.length;\n}\n\nconst tempRows = Array.isArray(raw.temperature && raw.temperature.data) ? raw.temperature.data : [];\nconst humidityRows = Array.isArray(raw.humidity && raw.humidity.data) ? raw.humidity.data : [];\nconst rainfallRows = Array.isArray(raw.rainfall && raw.rainfall.data) ? raw.rainfall.data : [];\n\nconst tempValues = tempRows\n    .map((row) => ({ place: row.place || \"Unknown\", value: toNumber(row.value) }))\n    .filter((row) => row.value !== null);\n\nconst humidityValues = humidityRows\n    .map((row) => toNumber(row.value))\n    .filter((v) => v !== null);\n\nconst rainfallValues = rainfallRows\n    .map((row) => ({ place: row.place || \"Unknown\", value: toNumber(row.max) }))\n    .filter((row) => row.value !== null);\n\nconst tempNums = tempValues.map((row) => row.value);\nconst avgTemp = avg(tempNums);\nconst avgHumidity = avg(humidityValues);\nconst maxRainfallRow = rainfallValues.length ? rainfallValues.reduce((a, b) => (a.value >= b.value ? a : b)) : null;\nconst hottestRow = tempValues.length ? tempValues.reduce((a, b) => (a.value >= b.value ? a : b)) : null;\n\nlet heatStress = null;\nif (avgTemp !== null && avgHumidity !== null) {\n    const rainfallFactor = maxRainfallRow ? Math.min(maxRainfallRow.value, 30) : 0;\n    heatStress = Math.round(Math.max(0, Math.min(100, (avgTemp * 2.2) + (avgHumidity * 0.45) + (rainfallFactor * 0.9) - 20)));\n}\n\nlet riskLevel = \"Unknown\";\nif (heatStress !== null) {\n    if (heatStress >= 80) {\n        riskLevel = \"Severe\";\n    } else if (heatStress >= 65) {\n        riskLevel = \"High\";\n    } else if (heatStress >= 45) {\n        riskLevel = \"Moderate\";\n    } else {\n        riskLevel = \"Low\";\n    }\n}\n\nmsg.payload = {\n    updateTime: updateISO,\n    collectedAt: new Date().toISOString(),\n    sourceUpdated: true,\n    stationCount: tempValues.length,\n    avgTemp: avgTemp !== null ? Number(avgTemp.toFixed(2)) : null,\n    minTemp: tempNums.length ? Number(Math.min.apply(null, tempNums).toFixed(2)) : null,\n    maxTemp: tempNums.length ? Number(Math.max.apply(null, tempNums).toFixed(2)) : null,\n    avgHumidity: avgHumidity !== null ? Number(avgHumidity.toFixed(2)) : null,\n    maxRainfall: maxRainfallRow ? Number(maxRainfallRow.value.toFixed(2)) : null,\n    maxRainfallDistrict: maxRainfallRow ? maxRainfallRow.place : null,\n    hottestStation: hottestRow ? hottestRow.place : null,\n    heatStress: heatStress,\n    riskLevel: riskLevel\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 710,
        "y": 150,
        "wires": [
            [
                "db.rt.insert"
            ]
        ]
    },
