    {
        "id": "fn.fc.to.chart",
        "type": "function",
        "z": "9f6b2c4a.d1e3f8",
        "name": "Format Forecast Chart",
        "func": "const payload = msg.payload || {};\nconst list = Array.isArray(payload.forecast) ? payload.forecast : [];\n\nfunction toNumber(v) {\n    const n = Number(v);\n    return Number.isFinite(n) ? n : null;\n}\n\nconst maxSeries = [];\nconst minSeries = [];\n\nfor (const item of list) {\n    const d = String(item.forecastDate || \"\");\n    if (d.length !== 8) {\n        continue;\n    }\n\n    const iso = d.slice(0, 4) + \"-\" + d.slice(4, 6) + \"-\" + d.slice(6, 8) + \"T12:00:00+08:00\";\n    const x = new Date(iso);\n\n    const yMax = toNumber(item.maxTemp);\n    const yMin = toNumber(item.minTemp);\n\n    if (yMax !== null) {\n        maxSeries.push({ x: x, y: yMax });\n    }\n    if (yMin !== null) {\n        minSeries.push({ x: x, y: yMin });\n    }\n}\n\nmsg.payload = [{\n    series: [\"Forecast Max (C)\", \"Forecast Min (C)\"],\n    data: [maxSeries, minSeries],\n    labels: [\"\"]\n}];\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 980,
        "y": 650,
        "wires": [
            [
                "chart.fc"
            ]
        ]
