        "func": "const end = new Date();\nconst start = new Date(end.getTime() - 24 * 60 * 60 * 1000);\nmsg.payload = {\n    collectedAt: {\n        $gt: start.toISOString(),\n        $lt: end.toISOString()\n    }\n};\nreturn msg;",
