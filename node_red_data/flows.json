        "id": "fn.fc.normalize",
        "type": "function",
        "z": "9f6b2c4a.d1e3f8",
        "name": "Normalize Forecast",
        "func": "const raw = msg.payload || {};\nconst list = Array.isArray(raw.weatherForecast) ? raw.weatherForecast : [];\n\nfunction toNumber(v) {\n    const n = Number(v);\n    return Number.isFinite(n) ? n : null;\n}\n\nconst forecast = list.slice(0, 9).map((item) => ({\n    forecastDate: item.forecastDate,\n    week: item.week,\n    minTemp: toNumber(item.forecastMintemp && item.forecastMintemp.value),\n    maxTemp: toNumber(item.forecastMaxtemp && item.forecastMaxtemp.value),\n    minRH: toNumber(item.forecastMinrh && item.forecastMinrh.value),\n    maxRH: toNumber(item.forecastMaxrh && item.forecastMaxrh.value),\n    weather: item.forecastWeather || \"\"\n}));\n\nmsg.payload = {\n    updateTime: new Date().toISOString(),\n    sourceUpdateTime: raw.updateTime || null,\n    forecast: forecast\n};\n\nreturn msg;",
